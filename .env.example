# Multi Shop Link 环境变量配置
# 复制此文件为 .env 并填入实际值

# [必填] JWT 认证密钥（任意随机字符串）
JWT_SECRET=your-random-secret-key-here

# [生产必填] 允许的前端域名（含协议，多个用逗号分隔）
# 例: CORS_ORIGIN=https://your-domain.com
# 例: CORS_ORIGIN=https://domain1.com,https://domain2.com,http://192.168.1.100:3001
CORS_ORIGIN=

# [可选] 服务端口（默认 3001）
PORT=3001